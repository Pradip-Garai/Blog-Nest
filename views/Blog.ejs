<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>

    <!-- Google Fonts: Inter (Sans) & Playfair Display (Serif) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,700;1,400&display=swap" rel="stylesheet">
</head>

<body class="blog-body">

    <%- include('./partials/Nav') %>

    <!-- Scroll Progress Indicator -->
    <div class="scroll-progress-container">
        <div class="scroll-progress-bar" id="scrollProgress"></div>
    </div>

    <!-- Main Blog Wrapper -->
    <main class="blog-wrapper">

        <!-- Breadcrumbs & Category Bar -->
        <div class="container blog-breadcrumb-container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/">Articles</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Read</li>
                </ol>
            </nav>
        </div>

        <!-- Main Blog Header -->
        <section class="blog-header-section">
            <div class="container">
                
                <!-- Category Tag -->
                <div class="blog-category-badge">
                    <%= blog.blogTopic %>
                </div>

                <!-- Title -->
                <h1 class="blog-main-title">
                    <%= blog.title %>
                </h1>

                <!-- Meta Details & Flat Social Row -->
                <div class="blog-meta-divider-top"></div>
                <div class="blog-header-meta">
                    <div class="author-profile-row">
                        <div class="author-avatar-circle">
                            <% if (blog.createdBy?.profilePicture) { %>
                                <img src="<%= blog.createdBy.profilePicture %>" 
                                     alt="<%= blog.createdBy.fullName %>" 
                                     class="author-avatar-img"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            <% } %>
                            <div class="author-avatar-fallback" style="display: <%= blog.createdBy?.profilePicture ? 'none' : 'flex' %>;">
                                <%= blog.createdBy?.fullName?.charAt(0).toUpperCase() || "A" %>
                            </div>
                        </div>

                        <div class="author-text-meta">
                            <span class="meta-label">Author</span>
                            <div class="author-name-link">
                                <%= blog.createdBy?.fullName || "Admin" %>
                            </div>
                            <div class="publish-time-row">
                                <span><%= new Date(blog.createdAt).toLocaleString('en-US', { 
                                    year: 'numeric', 
                                    month: 'short', 
                                    day: 'numeric',
                                    hour: 'numeric',
                                    minute: '2-digit',
                                    hour12: true
                                }) %></span>
                                <span class="meta-dot"></span>
                                <span>5 min read</span>
                            </div>
                        </div>
                    </div>

                    <!-- Flat Inline Actions -->
                    <div class="header-actions-row">
                    
                        <button class="flat-action-btn copy" id="copyBtn" onclick="copyArticleLink()" title="Copy Link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z"/>
                                <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z"/>
                            </svg>
                            Copy Link
                        </button>
                    </div>
                </div>
                <div class="blog-meta-divider-bottom"></div>
            </div>
        </section>

        <!-- Seamless Article Layout (No Boxed Cards) -->
        <section class="blog-layout-section">
            <div class="container">
                <div class="row">
                    
                    <!-- Left: Main Paragraph Content Area -->
                    <div class="col-lg-8 blog-main-content-column">
                        
                        <!-- Article Main Cover -->
                        <div class="main-cover-wrapper mb-4">
                            <img 
                                src="<%= blog.coverImageURL %>" 
                                alt="<%= blog.title %>"
                                class="main-cover-image"
                            >
                        </div>

                        <!-- GFG / Medium Styled Main Article -->
                        <article class="gfg-article-content">
                            <p class="article-lead-paragraph"><%= blog.body %></p>
                        </article>

                        <!-- Flat Horizontal Separator -->
                        <div class="article-footer-separator my-5"></div>

                        <!-- Flat Feedback / Share area -->
                        <div class="article-footer-actions">
                            <div class="footer-action-label">Enjoyed reading? Share this technical deep-dive with your network:</div>
                            <div class="footer-share-buttons gap-2 mt-3">
                                <!-- <button class="footer-social-btn tw" onclick="shareTwitter()">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.6.016zm-.86 13.028h1.36L4.323 1.245H2.865l8.875 12.533z"/>
                                    </svg> Share on Twitter
                                </button> -->
                                <!-- <button class="footer-social-btn li" onclick="shareLinkedIn()">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
                                    </svg> Share on LinkedIn
                                </button> -->
                            </div>
                        </div>

                    </div>

                    <!-- Right Side Column: Clean Sidebar (GFG Style) -->
                    <div class="col-lg-4 blog-sidebar-column d-none d-lg-block">
                        <div class="blog-sidebar-sticky">
                            
                            <!-- Sidebar Author Bio -->
                            <div class="sidebar-widget author-widget-flat">
                                <h3 class="widget-title">About The Author</h3>
                                <div class="widget-author-card">
                                    <div class="widget-author-avatar">
                                        <% if (blog.createdBy?.profilePicture) { %>
                                            <img src="<%= blog.createdBy.profilePicture %>" 
                                                 alt="<%= blog.createdBy.fullName %>" 
                                                 class="author-avatar-img"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        <% } %>
                                        <div class="author-avatar-fallback" style="display: <%= blog.createdBy?.profilePicture ? 'none' : 'flex' %>;">
                                            <%= blog.createdBy?.fullName?.charAt(0).toUpperCase() || "A" %>
                                        </div>
                                    </div>
                                    <div class="widget-author-info">
                                        <h4 class="widget-author-name"><%= blog.createdBy?.fullName || "Admin" %></h4>
                                        <span class="widget-author-role">Contributor</span>
                                    </div>
                                </div>
                                <p class="widget-author-bio mt-3">
                                    Deep engineering advocate, writing about modern scalable web infrastructures, database structures, and backend systems.
                                </p>
                            </div>

                            <!-- Sidebar Quick Navigation Aids -->
                            <div class="sidebar-widget nav-widget-flat">
                                <h3 class="widget-title">Reading Insights</h3>
                                <ul class="insights-list">
                                    <li>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#3b82f6" class="bi bi-patch-check-fill" viewBox="0 0 16 16">
                                            <path d="M10.067.87a2.89 2.89 0 0 0-4.134 0l-.622.638-.89-.011a2.89 2.89 0 0 0-2.924 2.924l.01.89-.636.622a2.89 2.89 0 0 0 0 4.134l.637.622-.011.89a2.89 2.89 0 0 0 2.924 2.924l.89-.01.622.636a2.89 2.89 0 0 0 4.134 0l.622-.637.89.011a2.89 2.89 0 0 0 2.924-2.924l-.01-.89.636-.622a2.89 2.89 0 0 0 0-4.134l-.637-.622.011-.89a2.89 2.89 0 0 0-2.924-2.924l-.89.01-.622-.636zm.287 5.984-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708.708z"/>
                                        </svg>
                                        <span>Verified Technical Article</span>
                                    </li>
                                    <li>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#64748b" class="bi bi-journal-text" viewBox="0 0 16 16">
                                            <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                                            <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2zm0 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3z"/>
                                        </svg>
                                        <span>Continuous Updates</span>
                                    </li>
                                </ul>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </section>

    </main>

    <!-- Custom Modern Clipboard Copy Toast Notification -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="shareToast" class="toast align-items-center text-white bg-dark border-0 custom-toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#3b82f6" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                    </svg>
                    <span>Article link copied to clipboard!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts') %>

    <!-- Client-Side JavaScript logic -->
    <script>
        // Smoothly animate the top scroll progress bar
        window.addEventListener('scroll', () => {
            const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
            document.getElementById('scrollProgress').style.width = scrolled + '%';
        });

        // Interactive share links
        function shareTwitter() {
            const url = encodeURIComponent(window.location.href);
            const text = encodeURIComponent(document.title);
            window.open(`https://twitter.com/intent/tweet?url=${url}&text=${text}`, '_blank');
        }

        function shareLinkedIn() {
            const url = encodeURIComponent(window.location.href);
            window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, '_blank');
        }

        function copyArticleLink() {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
                // Initialize and show custom toast
                const toastEl = document.getElementById('shareToast');
                const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                toast.show();

                // Custom feedback on the Copy link button itself
                const copyBtn = document.getElementById('copyBtn');
                const originalHTML = copyBtn.innerHTML;
                copyBtn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-check2" viewBox="0 0 16 16">
                        <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
                    </svg>
                    Copied!
                `;
                copyBtn.style.color = '#10b981';
                copyBtn.style.backgroundColor = '#ecfdf5';
                copyBtn.style.borderColor = '#10b981';
                
                setTimeout(() => {
                    copyBtn.innerHTML = originalHTML;
                    copyBtn.style.color = '';
                    copyBtn.style.backgroundColor = '';
                    copyBtn.style.borderColor = '';
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy link: ', err);
            });
        }
    </script>

</body>
</html>

<style>
    /* DESIGN SYSTEM & GLOBAL RESET (GFG/Medium Editorial Palette) */
    :root {
        --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-serif: 'Playfair Display', Georgia, serif;
        
        /* GFG Clean Colorways */
        --bg-main: #ffffff;             /* Pure white background for high legibility */
        --bg-sidebar: #f8fafc;          /* Flat subtle light color for widgets */
        
        --text-primary: #1f2937;        /* Deep Gray/Off-Black for body content */
        --text-headings: #0f172a;       /* Dark slate for titles and subtitles */
        --text-muted: #64748b;          /* Cool grey for subtexts and meta */
        
        --border-flat: #e2e8f0;         /* GFG elegant borders */
        --border-focus: #3b82f6;        
        
        --primary: #2f80ed;             
        --primary-gradient: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body.blog-body {
        background: var(--bg-main);
        color: var(--text-primary);
        font-family: var(--font-primary);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        padding-top: 72px; /* Breathing room for the fixed top navbar */
    }

    /* SCROLL PROGRESS INDICATOR */
    .scroll-progress-container {
        position: fixed;
        top: 72px;
        left: 0;
        width: 100%;
        height: 3px;
        background: rgba(226, 232, 240, 0.6);
        z-index: 1050;
    }

    .scroll-progress-bar {
        height: 100%;
        width: 0%;
        background: var(--primary-gradient);
        transition: width 0.1s ease-out;
    }

    /* WRAPPER */
    .blog-wrapper {
        padding-bottom: 6rem;
    }

    /* BREADCRUMB */
    .blog-breadcrumb-container {
        max-width: 1200px;
        margin-top: 2rem;
        padding-left: 15px;
        padding-right: 15px;
    }

    .breadcrumb {
        margin-bottom: 0;
        background: transparent;
        padding: 0;
    }

    .breadcrumb-item, .breadcrumb-item a {
        font-size: 0.85rem;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
    }

    .breadcrumb-item a:hover {
        color: var(--primary);
    }

    .breadcrumb-item.active {
        color: var(--text-primary);
        font-weight: 600;
    }

    /* HEADER SECTION */
    .blog-header-section {
        padding-top: 1.5rem;
        padding-bottom: 2rem;
    }

    .blog-header-section .container {
        max-width: 1200px;
    }

    .blog-category-badge {
        display: inline-block;
        background: #eff6ff;
        color: #2563eb;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        margin-bottom: 1.25rem;
        border: 1px solid rgba(37, 99, 235, 0.1);
    }

    .blog-main-title {
        font-size: 3.2rem;
        line-height: 1.18;
        font-weight: 850;
        letter-spacing: -0.035em;
        color: var(--text-headings);
        max-width: 950px;
        margin-bottom: 1.5rem;
    }

    /* FLAT DIVIDERS */
    .blog-meta-divider-top {
        height: 1px;
        background: var(--border-flat);
        margin-top: 2rem;
    }

    .blog-meta-divider-bottom {
        height: 1px;
        background: var(--border-flat);
        margin-bottom: 2rem;
    }

    /* FLAT META ROW */
    .blog-header-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.2rem 0;
        flex-wrap: wrap;
        gap: 1.25rem;
    }

    .author-profile-row {
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .author-avatar-circle {
        position: relative;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        overflow: hidden;
        background: var(--slate-100);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border-flat);
    }

    .author-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .author-avatar-fallback {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: var(--primary-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
    }

    .author-text-meta {
        display: flex;
        flex-direction: column;
        line-height: 1.4;
    }

    .meta-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .author-name-link {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-headings);
    }

    .publish-time-row {
        display: flex;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
        gap: 0.4rem;
        margin-top: 1px;
    }

    .meta-dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--slate-300);
        display: inline-block;
    }

    /* FLAT HEADER ACTIONS */
    .header-actions-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .flat-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border: 1px solid var(--border-flat);
        background: transparent;
        color: var(--text-muted);
        padding: 0.45rem 0.9rem;
        font-size: 0.82rem;
        font-weight: 600;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .flat-action-btn:hover {
        color: var(--text-headings);
        border-color: var(--slate-400);
        background: var(--bg-sidebar);
    }

    .flat-action-btn.twitter:hover {
        color: #1da1f2;
        border-color: #1da1f2;
        background: rgba(29, 161, 242, 0.05);
    }

    .flat-action-btn.linkedin:hover {
        color: #0077b5;
        border-color: #0077b5;
        background: rgba(0, 119, 181, 0.05);
    }

    .flat-action-btn.copy:hover {
        color: var(--primary);
        border-color: var(--primary);
        background: rgba(47, 128, 237, 0.05);
    }

    /* SEAMLESS TWO-COLUMN LAYOUT */
    .blog-layout-section .container {
        max-width: 1200px;
    }

    .blog-main-content-column {
        padding-right: 2.5rem;
    }

    /* COVER IMAGE */
    .main-cover-wrapper {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border-flat);
    }

    .main-cover-image {
        width: 100%;
        height: auto;
        max-height: 480px;
        object-fit: cover;
        display: block;
    }

    /* ARTICLE PARAGRAPHS (GFG STYLE) */
    .gfg-article-content {
        font-size: 1.12rem;
        line-height: 1.85;
        color: var(--text-primary);
        font-weight: 400;
        text-align: left; /* Left align for professional editorial paragraphs */
    }

    .gfg-article-content p {
        white-space: pre-line;
        margin-bottom: 1.8rem;
        letter-spacing: -0.005em;
        word-spacing: 0.5px;
    }

    /* LEAD PARAGRAPH INTRO STYLE */
    .article-lead-paragraph {
        font-size: 1.18rem;
        line-height: 1.9;
        color: #111827;
    }

    /* FLAT SEPARATORS */
    .article-footer-separator {
        height: 1px;
        background: var(--border-flat);
    }

    /* FOOTER ACTIONS */
    .article-footer-actions {
        padding: 1.5rem 0;
    }

    .footer-action-label {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-headings);
    }

    .footer-share-buttons {
        display: flex;
        flex-wrap: wrap;
    }

    .footer-social-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid var(--border-flat);
        background: #ffffff;
        color: var(--text-muted);
        padding: 0.55rem 1.1rem;
        font-size: 0.88rem;
        font-weight: 600;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .footer-social-btn:hover {
        background: var(--bg-sidebar);
        color: var(--text-headings);
        border-color: var(--slate-400);
    }

    .footer-social-btn.tw:hover {
        color: #1da1f2;
        border-color: #1da1f2;
        background: rgba(29, 161, 242, 0.05);
    }

    .footer-social-btn.li:hover {
        color: #0077b5;
        border-color: #0077b5;
        background: rgba(0, 119, 181, 0.05);
    }

    /* FLAT SIDEBAR COLUMN */
    .blog-sidebar-sticky {
        position: sticky;
        top: 100px; /* Aligns with fixed navbar + spacing */
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .sidebar-widget {
        background: var(--bg-sidebar);
        border: 1px solid var(--border-flat);
        border-radius: 8px;
        padding: 1.5rem;
    }

    .widget-title {
        font-size: 0.95rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--text-headings);
        letter-spacing: 0.05em;
        margin-bottom: 1.15rem;
