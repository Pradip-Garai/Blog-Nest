<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Signup Page</title>

    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow-x: hidden;
            overflow-y: hidden;
        }

        body {
            background: linear-gradient(135deg, #eaf1ff 0%, #f6f9ff 100%);
            font-family: 'Segoe UI', Roboto, sans-serif;
            margin-top: 70px;
        }

        .signup-wrapper {
            min-height: calc(100vh - 70px);
            padding: 24px;
            display: flex;
            align-items: center;
        }

        .signup-panel {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.12);
            background: #fff;
        }

        .panel-left {
            background: linear-gradient(135deg, #2f80ed 0%, #5b6cff 100%);
            color: #fff;
            padding: 60px 48px;
            min-height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .panel-left h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 18px;
            letter-spacing: -0.5px;
        }

        .panel-left p {
            font-size: 1.1rem;
            line-height: 1.8;
            opacity: 0.95;
            max-width: 520px;
        }

        .quote-box {
            margin-top: 28px;
            padding-left: 18px;
            border-left: 4px solid rgba(255,255,255,0.55);
            font-size: 1.05rem;
            font-style: italic;
            opacity: 0.95;
        }

        .panel-right {
            padding: 48px;
            background: rgba(255,255,255,0.96);
        }

        .signup-title {
            color: #102a43;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .signup-subtitle {
            color: #6c757d;
            margin-bottom: 26px;
        }

        .form-label {
            font-weight: 600;
            color: #102a43;
        }

        .form-control,
        .form-select {
            height: 48px;
            border-radius: 12px;
            border: 1px solid #d7e0ea;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #2f80ed;
            box-shadow: 0 0 0 0.2rem rgba(47, 128, 237, 0.15);
        }

        .btn-primary {
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #2f80ed 0%, #5b6cff 100%);
            border: none;
            font-weight: 700;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #1f6fe0 0%, #4c5df0 100%);
        }

        .form-text {
            color: #6c757d;
        }

        .signup-footer {
            text-align: center;
            margin-top: 16px;
            color: #6c757d;
        }

        .signup-footer a {
            color: #2f80ed;
            font-weight: 600;
            text-decoration: none;
        }

        .signup-footer a:hover {
            text-decoration: underline;
        }

        @media (max-width: 991px) {
            .panel-left, .panel-right {
                padding: 36px 24px;
            }

            .panel-left h1 {
                font-size: 2.2rem;
            }
        }

        @media (max-width: 767px) {
            html, body {
                overflow-y: auto;
            }

            .signup-wrapper {
                min-height: auto;
            }
        }
    </style>
</head>
<body>
    <%- include('./partials/Nav') %>

    <div class="signup-wrapper">
        <div class="signup-panel">
            <div class="row g-0">
                <div class="col-lg-6 panel-left">
                    <h1>Join BlogNest</h1>
                    <p>
                        Create your account and start sharing your stories with the world.
                        Write, publish, and connect with readers in one place.
                    </p>
                    <div class="quote-box">
                        “A great story deserves a great place to begin.”
                    </div>
                </div>

                <div class="col-lg-6 panel-right">
                    <h2 class="signup-title">Sign Up</h2>
                    <p class="signup-subtitle">Fill in your details to create your account</p>

                    <form action="/auth/api/register" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="fullName" class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="fullName" name="fullName" placeholder="Enter your full name">
                                <div class="form-text">You can add middle name, if you have</div>
                            </div>

                            <div class="col-md-6">
                                <label for="gender" class="form-label">Gender</label>
                                <select class="form-select" name="gender" id="gender">
                                    <option selected disabled>Select Your Gender</option>
                                    <option value="male">Male</option>
                                    <option value="female">Female</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="email" class="form-label">Email address</label>
                                <input type="email" name="email" class="form-control" id="email" placeholder="name@example.com">
                                <div class="form-text">We'll never share your email with anyone else.</div>
                            </div>

                            <div class="col-md-6">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" id="password" placeholder="Create a strong password">
                                <div class="form-text">At least 8 characters recommended.</div>
                            </div>

                            <div class="col-12">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="exampleCheck1">
                                    <label class="form-check-label" for="exampleCheck1">I agree to the Terms of Service</label>
                                </div>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100">Submit</button>
                            </div>

                            <div class="col-12 signup-footer">
                                Already have an account? <a href="/login">Login</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>