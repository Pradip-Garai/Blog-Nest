<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>My Blogs</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f5f5;
            color: #333;
            margin-top: 70px;
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header/Hero Section */
        .page-header {
            text-align: center;
            margin-bottom: 40px;
            padding: 40px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 16px;
            color: white;
        }

        .page-header h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }

        .page-header p {
            font-size: 18px;
            opacity: 0.95;
            max-width: 600px;
            margin: 0 auto;
        }

        .page-header .blog-count {
            font-size: 16px;
            margin-top: 15px;
            opacity: 0.9;
            font-weight: 500;
        }

        /* Blog Grid - 3 cards per row */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 20px;
        }

        /* Card Design */
        .card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        }

        /* Card Image Cap */
        .card-img-top {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background-color: #f0f0f0;
        }

        /* Card Body */
        .card-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        /* Card Title */
        .card-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #333;
            line-height: 1.3;
        }

        /* Card Meta */
        .card-meta {
            font-size: 12px;
            color: #999;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-meta .meta-badge {
            background: #f0f0f0;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 500;
            color: #667eea;
        }

        /* Card Text */
        .card-text {
            font-size: 14px;
            color: #666;
            line-height: 1.5;
            margin-bottom: 20px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            flex-grow: 1;
        }

        /* Button Actions */
        .card-actions {
            display: flex;
            gap: 12px;
            margin-top: auto;
        }

        .btn {
            flex: 1;
            padding: 10px 16px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn-read {
            background: #667eea;
            color: white;
        }

        .btn-read:hover {
            background: #5a67d8;
            transform: translateY(-2px);
        }

        .btn-delete {
            background: #f5f5f5;
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .btn-delete:hover {
            background: #dc3545;
            color: white;
            transform: translateY(-2px);
        }

        .btn-delete:active {
            opacity: 0.9;
        }

        /* No blogs message */
        .no-blogs {
            text-align: center;
            padding: 80px 20px;
            background: white;
            border-radius: 12px;
            grid-column: 1 / -1;
        }

        .no-blogs h3 {
            font-size: 28px;
            margin-bottom: 12px;
            color: #333;
            font-weight: 600;
        }

        .no-blogs p {
            color: #666;
            font-size: 16px;
            margin-bottom: 24px;
        }

        .no-blogs .btn {
            background: #667eea;
            color: white;
            padding: 12px 24px;
            display: inline-block;
            text-decoration: none;
        }

        .no-blogs .btn:hover {
            background: #5a67d8;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .blog-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 25px;
            }
        }

        @media (max-width: 768px) {
            .page-header h1 {
                font-size: 32px;
            }
            .blog-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .container {
                padding: 20px;
            }
        }

        /* Loading and Delete Animation */
        .card.deleting {
            opacity: 0.6;
            pointer-events: none;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
    </style>
</head>
<body>
    <%- include('./partials/Nav') %>

    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>📚 My Blogs</h1>
            <p>Manage and view all your published blog posts</p>
            <% if (blogs && blogs.length > 0) { %>
                <div class="blog-count">
                    You have published <strong><%= blogs.length %></strong> blog<%= blogs.length !== 1 ? 's' : '' %>
                </div>
            <% } %>
        </div>

        <!-- Blog Grid -->
        <div class="blog-grid" id="blogGrid">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="card" data-blog-id="<%= blog._id %>">
                        <img src="<%= blog.coverImageURL || 'https://via.placeholder.com/300x200?text=No+Image' %>" 
                             class="card-img-top" 
                             alt="<%= blog.title %>"
                             loading="lazy"
                             onerror="this.src='https://via.placeholder.com/300x200?text=Image+Not+Found'">
                        <div class="card-body">
                            <h5 class="card-title"><%= blog.title %></h5>
                            
                            <div class="card-meta">
                                <span class="meta-badge"><%= blog.blogTopic || 'General' %></span>
                                <span>•</span>
                                <span><%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                            </div>

                            <p class="card-text"><%= blog.body.substring(0, 100) %>...</p>

                            <div class="card-actions">
                                <% if (blog._id) { %>
                                    <a href="/blog/<%= blog._id %>" class="btn btn-read">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                                        </svg>
                                        Read
                                    </a>
                                    <button class="btn btn-delete" onclick="deleteBlog('<%= blog._id %>')">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1V3ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                        </svg>
                                        Delete
                                    </button>
                                <% } else { %>
                                    <span class="btn" style="opacity: 0.5; cursor: not-allowed;">Unavailable</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-blogs">
                    <h3>📝 No blogs yet</h3>
                    <p>Start sharing your thoughts with the world!</p>
                    <a href="/add-blog" class="btn">Create Your First Blog</a>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        async function deleteBlog(blogId) {
            if (!confirm('Are you sure you want to delete this blog? This action cannot be undone.')) {
                return;
            }

            const cardElement = document.querySelector(`[data-blog-id="${blogId}"]`);
            if (cardElement) {
                cardElement.classList.add('deleting');
            }

            try {
                const response = await fetch(`/blog/delete/${blogId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    // Remove card from DOM
                    cardElement.style.animation = 'slideOut 0.3s ease-out';
                    setTimeout(() => {
                        cardElement.remove();
                        
                        // Check if no blogs left
                        const remainingCards = document.querySelectorAll('.card[data-blog-id]');
                        if (remainingCards.length === 0) {
                            location.reload();
                        }
                    }, 300);
                } else {
                    alert(data.error || 'Failed to delete blog');
                    if (cardElement) {
                        cardElement.classList.remove('deleting');
                    }
                }
            } catch (err) {
                console.error('Error deleting blog:', err);
                alert('Error deleting blog. Please try again.');
                if (cardElement) {
                    cardElement.classList.remove('deleting');
                }
            }
        }

        // Add animation keyframes
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideOut {
                to {
                    opacity: 0;
                    transform: translateX(100%);
                }
            }
        `;
        document.head.appendChild(style);
    </script>

    <%- include('./partials/scripts') %>
</body>
</html>